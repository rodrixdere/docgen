{
  "name": "docwizard",
  "version": "2.1.0",
  "description": "Scan your project and get a plain-language user guide instantly. Powered by Groq.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "docwizard": "dist/index.js"
  },
  "scripts": {
    "build": "rm -rf dist && tsc",
    "dev": "tsx src/index.ts",
    "test": "tsx src/builder.test.ts",
    "prepublishOnly": "npm run build",
    "release": "npm run build && npm publish && npm install -g docwizard"
  },
  "keywords": [
    "cli",
    "documentation",
    "user-guide",
    "developer-tools",
    "docgen",
    "ai",
    "groq",
    "markdown",
    "scanner"
  ],
  "license": "MIT",
  "dependencies": {
    "@inquirer/prompts": "^7.5.2",
    "chalk": "^5.4.1",
    "log-symbols": "^7.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
